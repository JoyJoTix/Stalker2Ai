<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Stalker2Ai" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Стандартные цвета, чтобы убрать системный фиолетовый -->
        <item name="colorPrimary">@color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Убираем полосу при запуске (Starting Window) -->
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <style name="Theme.Stalker2Ai" parent="Base.Theme.Stalker2Ai" />
</resources>