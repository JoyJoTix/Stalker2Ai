<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <EditText
        android:id="@+id/etAuthKey"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:hint="Auth Key"
        android:textSize="14sp"
        android:inputType="text"
        app:layout_constraintEnd_toStartOf="@+id/btnSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/settings_title"
        android:src="@drawable/ic_settings_gear"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnBluetoothSettings"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:drawablePadding="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="@string/btn_bluetooth"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnSettings" />

    <Button
        android:id="@+id/btnWifiSettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:drawablePadding="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="@string/btn_wifi"
        app:layout_constraintEnd_toEndOf="@+id/btnBluetoothSettings"
        app:layout_constraintStart_toStartOf="@+id/btnBluetoothSettings"
        app:layout_constraintTop_toBottomOf="@+id/btnBluetoothSettings" />

    <Button
        android:id="@+id/btnMobileSettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:drawablePadding="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="@string/btn_mobile"
        app:layout_constraintEnd_toEndOf="@+id/btnWifiSettings"
        app:layout_constraintStart_toStartOf="@+id/btnWifiSettings"
        app:layout_constraintTop_toBottomOf="@+id/btnWifiSettings" />

    <Button
        android:id="@+id/btnRefresh"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/btn_refresh"
        app:layout_constraintEnd_toEndOf="@+id/btnMobileSettings"
        app:layout_constraintStart_toStartOf="@+id/btnMobileSettings"
        app:layout_constraintTop_toBottomOf="@+id/btnMobileSettings" />

    <TextView
        android:id="@+id/tvDetectorStatus"
        android:layout_width="180dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_status_area"
        android:drawablePadding="8dp"
        android:gravity="center_vertical|start"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:text="@string/status_detector_off"
        android:textColor="@color/status_disconnected"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBluetoothSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnBluetoothSettings" />

    <TextView
        android:id="@+id/tvServerStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_status_area"
        android:drawablePadding="8dp"
        android:gravity="center_vertical|start"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:text="@string/status_server"
        android:textColor="@color/status_disconnected"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnWifiSettings"
        app:layout_constraintEnd_toEndOf="@+id/tvDetectorStatus"
        app:layout_constraintStart_toStartOf="@+id/tvDetectorStatus"
        app:layout_constraintTop_toTopOf="@+id/btnWifiSettings" />

    <TextView
        android:id="@+id/tvAuthStatus"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_status_area"
        android:drawablePadding="8dp"
        android:gravity="center_vertical|start"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:text="@string/status_auth"
        android:textColor="@color/status_disconnected"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnMobileSettings"
        app:layout_constraintEnd_toEndOf="@+id/tvServerStatus"
        app:layout_constraintStart_toStartOf="@+id/tvServerStatus"
        app:layout_constraintTop_toTopOf="@+id/btnMobileSettings" />

    <TextView
        android:id="@+id/tvFilesHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:text="@string/files_header"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnRefresh" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFiles"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/btnClearList"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvFilesHeader" />

    <Button
        android:id="@+id/btnClearList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_clear_list"
        android:textAllCaps="false"
        android:backgroundTint="@color/status_disconnected"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>